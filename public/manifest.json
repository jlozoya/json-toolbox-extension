{
  "manifest_version": 3,
  "name": "JSON Toolbox",
  "description": "Format, validate, inspect, and transform JSON directly in your browser.",
  "version": "0.1.3",
  "action": {
    "default_title": "JSON Toolbox",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "contextMenus", "scripting", "webRequest"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
